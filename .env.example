APPLICATION_PORT=8000
APPLICATION_BASE_URL="http://localhost:${APPLICATION_PORT}"

TELEGRAM_URL_BASE="https://api.telegram.org"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_URL="https://t.me/your_bot_username"
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=""


DEBUG=true

MYSQL_ROOT_PASSWORD=""
MYSQL_DATABASE_NAME=""
MYSQL_USERNAME=""
MYSQL_PASSWORD=""
MYSQL_PORT="3306"
MYSQL_URL="mysql://${MYSQL_USERNAME}:${MYSQL_PASSWORD}@db:${MYSQL_PORT}/${MYSQL_DATABASE_NAME}"

RABBITMQ_USER=
RABBITMQ_PASSWORD=

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL="amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbit_mq:${RABBITMQ_PORT}"

REDIS_PORT=6379
REDIS_URL="redis://redis:${REDIS_PORT}"
REDIS_SECRET_KEY=""

REVERSABLE_CIPHER_SECRET_KEY=

GITHUB_WEBHOOK_SECRET=
GITHUB_BASE="https://github.com"
GITHUB_API_BASE="https://api.github.com"
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY=
GITHUB_OAUTH_PATHNAME="/login/oauth/authorize"
GITHUB_OAUTH_CLIENT_SCOPE=user,repo,read:org
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

KAITEN_BASE=""
KAITEN_API_TOKEN=""

TASK_TRACKER_SPACE_ID=
TASK_TRACKER_QA_COLUMN_ID=
TASK_TRACKER_EXTRACT_PATTERN_REGEXP=""
TASK_TRACKER_PATH_TO_CARD="/space/${TASK_TRACKER_SPACE_ID}/boards/card/{id}"

NOTIFICATIONS_DEFAULT_DND_START="20:00"
NOTIFICATIONS_DEFAULT_DND_END="10:00"
NOTIFICATIONS_DEFAULT_TIMEZONE="Europe/Moscow"
REVIEW_RE_REVIEW_NUDGE_DEDUP_HOURS=12
REVIEW_STALE_THRESHOLD_HOURS=24

RELEASE_PLAN_DEFAULT_CALL_WEEKDAY="monday"
RELEASE_PLAN_DEFAULT_CALL_TIME="16:00"

# Monitoring (docker-compose.monitoring.yml)
# admin / admin — небезопасный дефолт. В проде/деве задайте сильный пароль.
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"

# OpenTelemetry tracing → Tempo
# OTEL_EXPORTER_OTLP_ENDPOINT зависит от того, где бежит бот:
#   - бот в docker-контейнере, Tempo тоже в контейнере → http://host.docker.internal:4318
#   - бот на хосте, Tempo в контейнере                  → http://localhost:4318
#   - оба в одной docker-сети                           → http://tempo:4318
OTEL_ENABLED="true"
OTEL_EXPORTER_OTLP_ENDPOINT="http://host.docker.internal:4318"
