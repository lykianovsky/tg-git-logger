        {"expr": "histogram_quantile(0.95, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "P95 {{route}}"},
        {"expr": "histogram_quantile(0.99, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "P99 {{route}}"}
